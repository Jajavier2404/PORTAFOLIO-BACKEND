# Puerto del servidor
PORT=3001

# URL de conexión a PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:TU_CONTRASEÑA@localhost:5432/portfolio?schema=public"

# Clave secreta para JWT (cambia esto en producción)
JWT_SECRET=tu-clave-secreta-super-segura-cambia-esto-en-produccion

# URL del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# API Key de Hugging Face (opcional)
# Obtén tu API key gratuita en: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=tu-api-key-de-huggingface-aqui

# Nombre de usuario de GitHub para sincronización
GITHUB_USERNAME=jajavier2404
